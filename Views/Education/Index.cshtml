@{
    ViewData["Title"] = "Tutoriály";
}

<div class="education-page">
    <div class="education-header">
        <h1>Tutoriály</h1>
        <p>Vyber si oblasť, ktorú chceš preskúmať.</p>
    </div>

    <div class="education-grid">
        <a asp-controller="Education" asp-action="NutritionBasics" class="education-card">
            <img src="@Url.Content("~/images/education/nutrition.jpg")" alt="Základy výživy" />
            <div class="education-overlay"></div>
            <div class="education-content">
                <h2>Základy výživy</h2>
                <p>Kalórie, makrá a zdravé stravovanie</p>
            </div>
        </a>

        <a asp-controller="Education" asp-action="TrainingBasics" class="education-card">
            <img src="@Url.Content("~/images/education/training.jpg")" alt="Ako cvičiť" />
            <div class="education-overlay"></div>
            <div class="education-content">
                <h2>Základy tréningu</h2>
                <p>Základy tréningu pre začiatočníkov</p>
            </div>
        </a>

        <a asp-controller="Education" asp-action="Exercises" class="education-card">
            <img src="@Url.Content("~/images/education/exercises.jpg")" alt="Databáza cvikov" />
            <div class="education-overlay"></div>
            <div class="education-content">
                <h2>Databáza cvikov</h2>
                <p>Videá cvikov podľa svalových partií</p>
            </div>
        </a>

        <a asp-controller="Calculators" asp-action="Index" class="education-card">
            <img src="@Url.Content("~/images/education/calculators.jpg")" alt="Kalkulačky" />
            <div class="education-overlay"></div>
            <div class="education-content">
                <h2>Kalkulačky</h2>
                <p>BMI, BMR a denný kalorický príjem</p>
            </div>
        </a>
    </div>
</div>