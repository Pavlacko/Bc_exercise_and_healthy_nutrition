@model List<Bc_exercise_and_healthy_nutrition.Models.Exercise>

@{
    ViewData["Title"] = "Databáza cvikov";
    var muscleGroups = Model
        .Select(e => e.MuscleGroup)
        .Where(g => !string.IsNullOrWhiteSpace(g))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
}

<div class="exercise-library-page">
    <div class="exercise-library-header">
        <h1>Databáza cvikov</h1>
        <p>Vyber si cvik podľa svalovej partie a pozri si jeho prevedenie.</p>
    </div>

    <div class="exercise-filters">
        <button type="button" class="exercise-filter-btn active" data-filter="all">Všetko</button>

        @foreach (var group in muscleGroups)
        {
            <button type="button" class="exercise-filter-btn" data-filter="@group">
                @group
            </button>
        }
    </div>

    @foreach (var group in Model
            .Where(e => !string.IsNullOrWhiteSpace(e.MuscleGroup))
            .GroupBy(e => e.MuscleGroup))
    {
        <section class="exercise-group-section" data-muscle-group="@group.Key">
            <h2 class="exercise-group-title">@group.Key</h2>

            <div class="exercise-grid">
                @foreach (var exercise in group)
                {
                    <div class="exercise-card">
                        <div class="exercise-video-wrapper">
                            <video controls preload="none">
                                <source src="@exercise.VideoPath" type="video/mp4" />
                            </video>
                        </div>

                        <a asp-controller="Education" asp-action="ExerciseDetails" asp-route-id="@exercise.Id" class="exercise-card-body-link">
                            <div class="exercise-card-body">
                                <h3>@exercise.Name</h3>
                                <p>@exercise.MuscleGroup</p>
                                <span class="exercise-open-text">
                                    Zobraziť podrobnosti <span class="exercise-arrow">→</span>
                                </span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const buttons = document.querySelectorAll(".exercise-filter-btn");
            const sections = document.querySelectorAll(".exercise-group-section");

            buttons.forEach(button => {
                button.addEventListener("click", function () {
                    const filter = this.dataset.filter;

                    buttons.forEach(btn => btn.classList.remove("active"));
                    this.classList.add("active");

                    sections.forEach(section => {
                        const muscleGroup = section.dataset.muscleGroup;

                        if (filter === "all" || muscleGroup === filter) {
                            section.style.display = "block";
                        } else {
                            section.style.display = "none";
                        }
                    });
                });
            });
        });
    </script>
}