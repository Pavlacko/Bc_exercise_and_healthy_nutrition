@using Bc_exercise_and_healthy_nutrition.Models
@{
    ViewData["Title"] = "Priatelia";
    var friends = ViewBag.Friends as List<FriendRequest> ?? new List<FriendRequest>();
    var requests = ViewBag.Requests as List<FriendRequest> ?? new List<FriendRequest>();
    var currentUserId = Context.Session.GetInt32("UserId");
}

<div class="container py-4">
    <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
        <h2 class="mb-3">Vyhľadať používateľa</h2>
        <input id="searchInput" class="form-control" placeholder="Zadaj meno..." />
        <div id="searchResults" class="mt-3"></div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
        <h3 class="mb-3">Žiadosti o priateľstvo</h3>

        @if (!requests.Any())
        {
            <p class="text-muted mb-0">Nemáš žiadne čakajúce žiadosti.</p>
        }
        else
        {
            @foreach (var r in requests)
            {
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>@(r.Sender?.Meno ?? "Neznámy používateľ")</span>
                    <div>
                        <button onclick="accept(@r.Id)" class="btn btn-success btn-sm">Prijať</button>
                        <button onclick="reject(@r.Id)" class="btn btn-danger btn-sm">Odmietnuť</button>
                    </div>
                </div>
            }
        }
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4">
        <h3 class="mb-3">Moji priatelia</h3>

        @if (!friends.Any())
        {
            <p class="text-muted mb-0">Zatiaľ nemáš žiadnych priateľov.</p>
        }
        else
        {
            @foreach (var f in friends)
            {
                var friend = f.SenderId == currentUserId ? f.Receiver : f.Sender;

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>@(friend?.Meno ?? "Neznámy používateľ")</span>
                    @if (friend != null)
                    {
                        <a href="/Stats/User/@friend.Id" class="btn btn-primary btn-sm">
                            Zobraziť profil
                        </a>
                    }
                </div>
            }
        }
    </div>
</div>

<script src="~/js/friends.js"></script>