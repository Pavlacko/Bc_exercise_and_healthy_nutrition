@using Bc_exercise_and_healthy_nutrition.Models
@{
    ViewData["Title"] = "Priatelia";

    var friends = ViewBag.Friends as List<FriendRequest> ?? new List<FriendRequest>();
    var requests = ViewBag.Requests as List<FriendRequest> ?? new List<FriendRequest>();
    var sentRequests = ViewBag.SentRequests as List<FriendRequest> ?? new List<FriendRequest>();
    var currentUserId = Context.Session.GetInt32("UserId");
}

<div class="container py-4">
    <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
        <h2 class="mb-3">Vyhľadať používateľa</h2>
        <input id="searchInput" class="form-control" placeholder="Zadaj meno používateľa..." />
        <div id="searchResults" class="mt-3"></div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
        <h3 class="mb-3">Čakajúce žiadosti</h3>

        @if (!requests.Any())
        {
            <p class="text-muted mb-0">Nemáš žiadne čakajúce žiadosti.</p>
        }
        else
        {
            @foreach (var r in requests)
            {
                <div class="friend-row">
                    <div class="friend-row-left">
                        <div class="friend-name">@(r.Sender?.Meno ?? "Neznámy používateľ")</div>
                        <div class="friend-email">@(r.Sender?.Email ?? "")</div>
                    </div>

                    <div class="friend-actions">
                        <button onclick="accept(@r.Id)" class="btn btn-main btn-sm friend-btn">Prijať</button>
                        <button onclick="reject(@r.Id)" class="btn btn-outline-danger btn-sm friend-btn">Odmietnuť</button>
                    </div>
                </div>
            }
        }
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
        <h3 class="mb-3">Odoslané žiadosti</h3>

        @if (!sentRequests.Any())
        {
            <p class="text-muted mb-0">Nemáš žiadne odoslané žiadosti.</p>
        }
        else
        {
            @foreach (var r in sentRequests)
            {
                <div class="friend-row">
                    <div class="friend-row-left">
                        <div class="friend-name">@(r.Receiver?.Meno ?? "Neznámy používateľ")</div>
                        <div class="friend-email">@(r.Receiver?.Email ?? "")</div>
                    </div>

                    <div class="friend-actions">
                        <span class="friend-pill-muted">Čaká na prijatie</span>
                    </div>
                </div>
            }
        }
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4">
        <h3 class="mb-3">Moji priatelia</h3>

        @if (!friends.Any())
        {
            <p class="text-muted mb-0">Zatiaľ nemáš žiadnych priateľov.</p>
        }
        else
        {
            @foreach (var f in friends)
            {
                var friend = f.SenderId == currentUserId ? f.Receiver : f.Sender;

                <div class="friend-row">
                    <div class="friend-row-left">
                        <div class="friend-name">@(friend?.Meno ?? "Neznámy používateľ")</div>
                        <div class="friend-email">@(friend?.Email ?? "")</div>
                    </div>

                    @if (friend != null)
                    {
                        <div class="friend-actions">
                            <a href="/Stats/User/@friend.Id" class="btn btn-main btn-sm friend-btn">
                                Zobraziť profil
                            </a>

                            <button type="button" class="btn btn-danger btn-sm friend-btn" onclick="removeFriend(@friend.Id)">
                                Odstrániť priateľa
                            </button>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/friends.js" asp-append-version="true"></script>
}