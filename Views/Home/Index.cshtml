@{
    ViewData["Title"] = "Domov";
}

<div class="home-hero home-hero-full">
    <div class="home-hero-content">
        <span class="home-badge">
            <i class="bi bi-heart-pulse-fill"></i>
            Healthy Start
        </span>

        <h1>Začni budovať zdravé návyky jednoducho a prehľadne</h1>

        <p>
            Sleduj svoj jedálniček, analyzuj makroživiny, zapisuj si tréningy
            a získaj užitočné informácie o strave a cvičení na jednom mieste.
        </p>

    </div>
</div>

<div class="home-sections home-sections-full">
    <a asp-controller="Diary" asp-action="Index" class="home-section-card card-diary">
        <div class="home-section-overlay"></div>
        <div class="home-section-content">
            <div class="home-section-icon">
                <i class="bi bi-journal-text"></i>
            </div>
            <div class="home-section-label">Denník</div>
            <div class="home-section-title">Strava</div>
            <div class="home-section-text">
                Zaznamenávaj jedlá a sleduj kalórie a makroživiny.
            </div>
        </div>
    </a>

    <a asp-controller="Stats" asp-action="Index" class="home-section-card card-stats">
        <div class="home-section-overlay"></div>
        <div class="home-section-content">
            <div class="home-section-icon">
                <i class="bi bi-bar-chart-line"></i>
            </div>
            <div class="home-section-label">Štatistiky</div>
            <div class="home-section-title">Prehľad</div>
            <div class="home-section-text">
                Vizualizácia progresu a vývoja hodnôt v čase.
            </div>
        </div>
    </a>

    <a asp-controller="Workout" asp-action="Index" class="home-section-card card-workout">
        <div class="home-section-overlay"></div>
        <div class="home-section-content">
            <div class="home-section-icon">
                <i class="bi bi-activity"></i>
            </div>
            <div class="home-section-label">Môj tréning</div>
            <div class="home-section-title">Výkon</div>
            <div class="home-section-text">
                Sleduj svoje tréningy, objem a aktivitu.
            </div>
        </div>
    </a>

    <a asp-controller="Education" asp-action="Index" class="home-section-card card-education">
        <div class="home-section-overlay"></div>
        <div class="home-section-content">
            <div class="home-section-icon">
                <i class="bi bi-book"></i>
            </div>
            <div class="home-section-label">Tutoriály</div>
            <div class="home-section-title">Návody</div>
            <div class="home-section-text">
                Získaj užitočné informácie o strave a cvičení.
            </div>
        </div>
    </a>
</div>